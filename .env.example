# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_hex_secret
ENCRYPTION_SECRET=replace_with_any_long_random_string

# ─── Database ─────────────────────────────────────────────────────────────────
# Leave blank to use the default path: server/data/simple-ui.sqlite
DB_PATH=
# For production PostgreSQL (NODE_ENV=production):
# DATABASE_URL=postgresql://user:password@host:5432/simple_ui

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Development: use FakeSMTP (no auth, no TLS)
#   java -jar fakeSMTP.jar -s -p 2525 -o /tmp/fakesmtp-emails
SMTP_HOST=127.0.0.1
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Simple UI <noreply@localhost>

# Production: real SMTP (Gmail, SES, etc.)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM=Simple UI <noreply@yourdomain.com>

# ─── Client ───────────────────────────────────────────────────────────────────
# Must match the URL where the React app is served
CLIENT_URL=http://localhost:5173
